{
  "name": "@sx3/i18n",
  "type": "module",
  "version": "0.1.2",
  "description": "A simple, lightweight localization system",
  "author": "SX3",
  "license": "MIT",
  "homepage": "https://github.com/SX-3/i18n",
  "repository": {
    "type": "git",
    "url": "https://github.com/SX-3/i18n"
  },
  "bugs": {
    "url": "https://github.com/SX-3/i18n/issues"
  },
  "keywords": [
    "i18n",
    "localization"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./*": {
      "types": "./dist/*.d.mts",
      "import": "./dist/*.mjs",
      "default": "./dist/*.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint",
    "build": "tsdown",
    "test": "bun test && bunx tsc --noEmit"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@types/bun": "latest",
    "eslint": "^9.39.4",
    "eslint-plugin-format": "^1.5.0",
    "tsdown": "^0.20.3"
  }
}
